digraph download_seq {
  rankdir=TB;
  bgcolor="white";
  fontname="Helvetica";
  labelloc="t";
  label="Download sequence (BlobStore.get)";
  fontsize=14;
  node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, color="#3b4d61", fillcolor="#eaeef2"];
  edge [fontname="Helvetica", fontsize=9, color="#3b4d61"];

  d1 [label="① Application calls\nget(blobId)", fillcolor="#dfe7f3"];
  d2 [label="② BlobStore →\nCouchbase.get(blobId)"];
  d3 [label="③ Couchbase returns\nmetadata JSON\n(s3Bucket, s3Key, ...)"];
  d4 [label="④ BlobStore →\nS3.GetObject(bucket, key)"];
  d5 [label="⑤ S3 returns\nstreaming response", fillcolor="#fdf0d5"];
  d6 [label="⑥ BlobStore returns\nInputStream — payload\nflows S3 → caller\n(no JVM buffering)", fillcolor="#dfffe6"];

  nf [label="✗ Not found →\nthrow\nBlobStoreException.NotFound", fillcolor="#fde2e2"];

  d1 -> d2 -> d3 -> d4 -> d5 -> d6;
  d2 -> nf [style=dashed, color="#b94a48", label="DocumentNotFoundException"];
}
