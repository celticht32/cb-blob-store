digraph monitoring {
  rankdir=LR;
  bgcolor="white";
  fontname="Helvetica";
  labelloc="t";
  label="Monitoring topology";
  fontsize=14;
  node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, color="#3b4d61", fillcolor="#eaeef2"];
  edge [fontname="Helvetica", fontsize=9, color="#3b4d61"];

  subgraph cluster_jvm {
    label="cb-blob-store-rest JVM";
    style="filled,rounded";
    fillcolor="#fafbfc";
    color="#bcc4cf";
    fontsize=12;

    Lib [label="BlobStore library\n(counters, timers,\ndistribution summaries)", fillcolor="#dfe7f3"];
    JavalinM [label="javalin-micrometer\n(per-route request metrics)", fillcolor="#dfe7f3"];
    JVMBinders [label="JVM/system binders\n(memory, GC, threads,\nuptime, classloader, CPU)", fillcolor="#dfe7f3"];

    Composite [label="CompositeMeterRegistry", fillcolor="#fdf0d5", shape=oval];
    Prom [label="PrometheusMeterRegistry"];
    Jmx  [label="JmxMeterRegistry"];

    Lib        -> Composite;
    JavalinM   -> Composite;
    JVMBinders -> Composite;
    Composite  -> Prom;
    Composite  -> Jmx;
  }

  PromHttp [label="GET /metrics\n(text/plain v0.0.4)", shape=note, fillcolor="#dfffe6"];
  JmxIface [label="JMX MBeans\n(metrics.* domain)", shape=note, fillcolor="#dfffe6"];

  Prom -> PromHttp [label="scrape", style=dashed];
  Jmx  -> JmxIface [label="register", style=dashed];

  Scrape [label="Prometheus server", shape=cylinder, fillcolor="#e8e3f0"];
  Graf   [label="Grafana", shape=oval, fillcolor="#e8e3f0"];
  JCons  [label="JConsole /\njmx_exporter", shape=oval, fillcolor="#e8e3f0"];

  PromHttp -> Scrape [label="HTTP scrape\n(default 15s)"];
  Scrape   -> Graf   [label="PromQL"];
  JmxIface -> JCons  [label="JMX RMI / agent"];
}
