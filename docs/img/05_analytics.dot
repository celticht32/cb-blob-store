digraph analytics {
  rankdir=LR;
  bgcolor="white";
  fontname="Helvetica";
  labelloc="t";
  label="Analytics service integration";
  fontsize=14;
  node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box, color="#3b4d61", fillcolor="#eaeef2"];
  edge [fontname="Helvetica", fontsize=9, color="#3b4d61"];

  App  [label="BlobStore client\n(application JVM)", fillcolor="#dfe7f3"];

  subgraph cluster_cb {
    label="Couchbase cluster";
    style="filled,rounded";
    fillcolor="#fafbfc";
    color="#bcc4cf";
    fontsize=12;
    Data [label="Data service\n(KV)", shape=cylinder, fillcolor="#fdf0d5"];
    Cbas [label="Analytics service\n(SQL++)", shape=cylinder, fillcolor="#e8e3f0"];
    Data -> Cbas [label="shadow link\n(seconds lag)", style=dashed, color="#7a6c9a"];
  }

  App -> Data [label="put / get / delete\n(KV)"];
  App -> Cbas [label="analytics().count()\nanalytics().summary()\n..."];
  Cbas -> App [label="rows", style=dashed];
}
